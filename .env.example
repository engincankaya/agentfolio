# =============================================================================
# Agenticfolio - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Provider (OpenRouter) ----------------------------------------------
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model selection (any OpenRouter-supported model)
LLM_MODEL=google/gemini-3.1-flash-lite-preview
EMBEDDING_MODEL=openai/text-embedding-3-small

# --- GitHub MCP Server -------------------------------------------------------
# Create a Personal Access Token at https://github.com/settings/tokens
# Required scopes: public_repo (read-only access to public repositories)
GITHUB_PAT=your_github_personal_access_token_here

# --- Google Calendar MCP Server (Optional) -----------------------------------
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Mindmap MCP Server (Optional) -------------------------------------------
# NPM package name. When set, the app runs it with: npx -y <package>
MINDMAP_MCP_PACKAGE=mindmap-mcp-server

# Absolute path to the mindmap MCP server's dist/index.js.
# Used only when MINDMAP_MCP_PACKAGE is empty.
MINDMAP_MCP_SERVER_PATH=

# --- Vector Database (Qdrant) ------------------------------------------------
# Qdrant Cloud connection. If QDRANT_URL is set, QDRANT_PATH is ignored.
QDRANT_URL=
QDRANT_API_KEY=

# Local storage path for embedded Qdrant fallback (auto-created on first run)
QDRANT_PATH=data/vector_db
QDRANT_COLLECTION=portfolio

# --- RAG Settings ------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=4

# --- LangSmith Observability (Optional) --------------------------------------
# Sign up at https://smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=agenticfolio
